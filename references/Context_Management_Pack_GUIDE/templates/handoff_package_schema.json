{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "handoff_v1",
  "type": "object",
  "required": [
    "handoff_id",
    "from_agent",
    "to_agent",
    "objective",
    "constraints",
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "handoff_v1"
    },
    "handoff_id": {
      "type": "string"
    },
    "from_agent": {
      "type": "string"
    },
    "to_agent": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "object"
    },
    "state": {
      "type": "object"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "uri"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "ttl": {
            "type": "string"
          }
        }
      }
    },
    "required_output_schema": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "budget_hint": {
      "type": "object",
      "properties": {
        "max_tokens": {
          "type": "integer"
        }
      }
    }
  }
}